{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "BlogPost",
  "type": "object",
  "$defs": {
    "Author": {
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "email": { "type": "string" },
        "bio": { "type": "string" }
      },
      "required": ["id", "name", "email"]
    },
    "Comment": {
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "text": { "type": "string" },
        "authorId": { "type": "string" },
        "createdAt": { "type": "string" }
      },
      "required": ["id", "text", "authorId", "createdAt"]
    }
  },
  "properties": {
    "id": { "type": "string" },
    "title": { "type": "string" },
    "content": { "type": "string" },
    "publishedAt": { "type": "string" },
    "viewCount": { "type": "number" },
    "tags": { "type": "array", "items": { "type": "string" } },
    "author": { "$ref": "#/$defs/Author" },
    "comments": { "type": "array", "items": { "$ref": "#/$defs/Comment" } }
  },
  "required": ["id", "title", "content", "publishedAt", "viewCount", "tags", "author", "comments"]
}
