{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://scalar.com/schemas/api-reference-configuration.json",
  "title": "Scalar API Reference Configuration",
  "description": "JSON Schema for Scalar API Reference configuration types from @scalar/types package",
  "type": "object",
  "definitions": {
    "securityScheme": {
      "type": "object",
      "properties": {
        "type": {
          "type": "string",
          "enum": ["apiKey", "http", "oauth2", "openIdConnect", "mutualTLS"]
        },
        "description": {
          "type": "string"
        },
        "name": {
          "type": "string"
        },
        "in": {
          "type": "string",
          "enum": ["query", "header", "cookie"]
        },
        "scheme": {
          "type": "string"
        },
        "bearerFormat": {
          "type": "string"
        },
        "flows": {
          "type": "object"
        },
        "openIdConnectUrl": {
          "type": "string",
          "format": "uri"
        },
        "value": {
          "type": "string",
          "description": "API Key value"
        },
        "token": {
          "type": "string",
          "description": "Bearer token"
        },
        "username": {
          "type": "string",
          "description": "Basic auth username"
        },
        "password": {
          "type": "string",
          "description": "Basic auth password"
        }
      }
    },
    "authenticationConfiguration": {
      "type": "object",
      "properties": {
        "preferredSecurityScheme": {
          "oneOf": [
            {
              "type": "string"
            },
            {
              "type": "array",
              "items": {
                "oneOf": [
                  {
                    "type": "string"
                  },
                  {
                    "type": "array",
                    "items": {
                      "type": "string"
                    }
                  }
                ]
              }
            },
            {
              "type": "null"
            }
          ],
          "description": "Preferred security scheme name(s) with OR/AND relationship support"
        },
        "securitySchemes": {
          "type": "object",
          "additionalProperties": {
            "$ref": "#/definitions/securityScheme"
          },
          "description": "Security schemes with overrides and additional properties"
        }
      }
    },
    "sourceConfiguration": {
      "type": "object",
      "properties": {
        "default": {
          "type": "boolean",
          "description": "Whether this is the default source"
        },
        "url": {
          "type": "string",
          "format": "uri",
          "description": "OpenAPI/Swagger document URL"
        },
        "content": {
          "oneOf": [
            {
              "type": "string"
            },
            {
              "type": "object"
            },
            {
              "type": "null"
            }
          ],
          "description": "OpenAPI/Swagger document content"
        },
        "title": {
          "type": "string",
          "description": "Document title (deprecated)"
        },
        "slug": {
          "type": "string",
          "description": "URL identifier (deprecated)"
        },
        "spec": {
          "type": "object",
          "description": "Legacy nested spec configuration (deprecated)",
          "properties": {
            "url": {
              "type": "string",
              "format": "uri"
            },
            "content": {
              "oneOf": [
                {
                  "type": "string"
                },
                {
                  "type": "object"
                },
                {
                  "type": "null"
                }
              ]
            }
          }
        },
        "agent": {
          "type": "object",
          "properties": {
            "key": {
              "type": "string",
              "description": "Agent API key"
            },
            "disabled": {
              "type": "boolean",
              "description": "Whether the agent is disabled"
            }
          }
        }
      }
    },
    "server": {
      "type": "object",
      "properties": {
        "url": {
          "type": "string",
          "format": "uri"
        },
        "description": {
          "type": "string"
        },
        "variables": {
          "type": "object",
          "additionalProperties": {
            "type": "object",
            "properties": {
              "default": {
                "type": "string"
              },
              "enum": {
                "type": "array",
                "items": {
                  "type": "string"
                }
              },
              "description": {
                "type": "string"
              }
            },
            "required": ["default"]
          }
        }
      },
      "required": ["url"]
    },
    "baseConfiguration": {
      "type": "object",
      "properties": {
        "title": {
          "type": "string",
          "description": "OpenAPI document title"
        },
        "slug": {
          "type": "string",
          "description": "URL identifier, derives from title if absent"
        },
        "authentication": {
          "$ref": "#/definitions/authenticationConfiguration",
          "description": "Authentication configuration"
        },
        "baseServerURL": {
          "type": "string",
          "format": "uri",
          "description": "API server base URL"
        },
        "hideClientButton": {
          "type": "boolean",
          "default": false,
          "description": "Client button visibility"
        },
        "proxyUrl": {
          "type": "string",
          "format": "uri",
          "description": "Request proxy endpoint"
        },
        "searchHotKey": {
          "type": "string",
          "pattern": "^[a-z]$",
          "description": "Modal trigger key (pairs with CTRL/CMD)"
        },
        "servers": {
          "type": "array",
          "items": {
            "$ref": "#/definitions/server"
          },
          "description": "OpenAPI server objects"
        },
        "showSidebar": {
          "type": "boolean",
          "default": true,
          "description": "Sidebar visibility"
        },
        "showDeveloperTools": {
          "type": "string",
          "enum": ["always", "localhost", "never"],
          "default": "localhost",
          "description": "Developer tools display setting"
        },
        "operationTitleSource": {
          "type": "string",
          "enum": ["summary", "path"],
          "default": "summary",
          "description": "Sidebar/search naming source"
        },
        "theme": {
          "type": "string",
          "enum": [
            "default",
            "alternate",
            "moon",
            "purple",
            "solarized",
            "bluePlanet",
            "saturn",
            "kepler",
            "mars",
            "deepSpace",
            "none",
            "pink",
            "elysiajs",
            "borderless"
          ],
          "default": "default",
          "description": "Theme name"
        },
        "_integration": {
          "type": "string",
          "description": "Framework/integration identifier"
        },
        "persistAuth": {
          "type": "boolean",
          "default": false,
          "description": "Local storage persistence for authentication"
        },
        "telemetry": {
          "type": "boolean",
          "default": true,
          "description": "Telemetry enabled state"
        }
      }
    },
    "apiReferenceConfiguration": {
      "allOf": [
        {
          "$ref": "#/definitions/baseConfiguration"
        },
        {
          "type": "object",
          "properties": {
            "layout": {
              "type": "string",
              "enum": ["modern", "classic"],
              "description": "Layout style"
            },
            "darkMode": {
              "type": "boolean",
              "description": "Enable dark mode"
            },
            "forceDarkModeState": {
              "type": "string",
              "enum": ["dark", "light"],
              "description": "Force specific mode state"
            },
            "hideDownloadButton": {
              "type": "boolean",
              "description": "Hide download button (deprecated, use documentDownloadType)"
            },
            "documentDownloadType": {
              "type": "string",
              "enum": ["json", "yaml", "none"],
              "description": "Document download format type"
            },
            "hideModels": {
              "type": "boolean",
              "default": false,
              "description": "Hide models/schemas section"
            },
            "hideExamples": {
              "type": "boolean",
              "default": false,
              "description": "Hide example requests/responses"
            },
            "hideDarkModeToggle": {
              "type": "boolean",
              "default": false,
              "description": "Hide dark mode toggle"
            },
            "hideTestRequestButton": {
              "type": "boolean",
              "default": false,
              "description": "Hide test request button"
            },
            "metaData": {
              "type": "object",
              "properties": {
                "title": {
                  "type": "string"
                },
                "description": {
                  "type": "string"
                },
                "ogTitle": {
                  "type": "string"
                },
                "ogDescription": {
                  "type": "string"
                },
                "ogImage": {
                  "type": "string",
                  "format": "uri"
                },
                "twitterCard": {
                  "type": "string"
                }
              },
              "description": "Meta tags for SEO and social sharing"
            },
            "favicon": {
              "type": "string",
              "format": "uri",
              "description": "Favicon URL"
            },
            "customCss": {
              "type": "string",
              "description": "Custom CSS styles"
            },
            "pathRouting": {
              "oneOf": [
                {
                  "type": "boolean"
                },
                {
                  "type": "object",
                  "properties": {
                    "basePath": {
                      "type": "string"
                    }
                  }
                }
              ],
              "description": "Enable path-based routing"
            },
            "tagsSorter": {
              "type": "string",
              "enum": ["alpha", "-alpha"],
              "description": "Tag sorting method"
            },
            "operationsSorter": {
              "type": "string",
              "enum": ["alpha", "-alpha", "method", "-method"],
              "description": "Operation sorting method"
            },
            "defaultOpenAllTags": {
              "type": "boolean",
              "default": false,
              "description": "Expand all tags by default"
            },
            "withDefaultFonts": {
              "type": "boolean",
              "default": true,
              "description": "Include default fonts"
            },
            "hiddenClients": {
              "type": "array",
              "items": {
                "type": "string"
              },
              "description": "List of hidden API client types"
            },
            "defaultHttpClient": {
              "type": "object",
              "properties": {
                "targetKey": {
                  "type": "string"
                },
                "clientKey": {
                  "type": "string"
                }
              },
              "description": "Default HTTP client configuration"
            },
            "proxy": {
              "type": "string",
              "description": "Proxy URL (deprecated, use proxyUrl)"
            },
            "showToolbar": {
              "type": "boolean",
              "description": "Show toolbar (deprecated, use showDeveloperTools)"
            }
          }
        }
      ]
    },
    "apiReferenceConfigurationWithSource": {
      "allOf": [
        {
          "$ref": "#/definitions/apiReferenceConfiguration"
        },
        {
          "$ref": "#/definitions/sourceConfiguration"
        }
      ]
    },
    "apiReferenceConfigurationWithMultipleSources": {
      "allOf": [
        {
          "$ref": "#/definitions/apiReferenceConfiguration"
        },
        {
          "type": "object",
          "properties": {
            "sources": {
              "type": "array",
              "items": {
                "$ref": "#/definitions/sourceConfiguration"
              },
              "description": "Multiple document sources"
            }
          }
        }
      ]
    },
    "htmlRenderingConfiguration": {
      "allOf": [
        {
          "$ref": "#/definitions/apiReferenceConfigurationWithMultipleSources"
        },
        {
          "type": "object",
          "properties": {
            "cdn": {
              "type": "string",
              "format": "uri",
              "default": "https://cdn.jsdelivr.net/npm/@scalar/api-reference",
              "description": "Scalar API Reference JS CDN URL for version pinning"
            },
            "pageTitle": {
              "type": "string",
              "default": "Scalar API Reference",
              "description": "HTML page title"
            }
          }
        }
      ]
    }
  },
  "oneOf": [
    {
      "$ref": "#/definitions/apiReferenceConfiguration",
      "description": "Basic API Reference configuration"
    },
    {
      "$ref": "#/definitions/apiReferenceConfigurationWithSource",
      "description": "API Reference configuration with a single source"
    },
    {
      "$ref": "#/definitions/apiReferenceConfigurationWithMultipleSources",
      "description": "API Reference configuration with multiple sources"
    },
    {
      "$ref": "#/definitions/htmlRenderingConfiguration",
      "description": "HTML rendering configuration"
    }
  ]
}
