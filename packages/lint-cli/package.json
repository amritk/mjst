{
  "name": "@amritk/lint-cli",
  "version": "0.0.0",
  "description": "Command-line interface for the JSON/YAML linter.",
  "type": "module",
  "license": "MIT",
  "author": "amritk",
  "keywords": [
    "lint",
    "linter",
    "cli",
    "json",
    "yaml",
    "mjst"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/amritk/mjst.git",
    "directory": "packages/lint-cli"
  },
  "homepage": "https://github.com/amritk/mjst/tree/main/packages/lint-cli#readme",
  "bugs": {
    "url": "https://github.com/amritk/mjst/issues"
  },
  "bin": {
    "lint": "./dist/index.js"
  },
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "dev": "bun run --conditions=development ./src/index.ts",
    "build": "tsgo -p tsconfig.build.json && tsc-alias -p tsconfig.build.json -f",
    "types:check": "tsgo -p . --noEmit",
    "test": "NODE_ENV=production vitest run --root ../.. lint-cli"
  },
  "exports": {
    ".": {
      "development": "./src/index.ts",
      "default": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "dependencies": {
    "@amritk/lint": "workspace:*",
    "@amritk/lint-core": "workspace:*",
    "@amritk/lint-formatters": "workspace:*",
    "@amritk/lint-parsers": "workspace:*",
    "fast-glob": "^3.3.2",
    "yargs": "^17.7.2"
  },
  "devDependencies": {
    "@types/yargs": "^17.0.33"
  }
}
