{
  "name": "@amritk/lint-functions",
  "version": "0.0.0",
  "description": "Built-in lint rule functions (truthy, pattern, schema, casing, alphabetical, ...).",
  "module": "./dist/index.js",
  "type": "module",
  "license": "MIT",
  "author": "amritk",
  "keywords": [
    "lint",
    "linter",
    "json-schema",
    "validation",
    "rules",
    "typescript",
    "mjst"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/amritk/mjst.git",
    "directory": "packages/lint-functions"
  },
  "homepage": "https://github.com/amritk/mjst/tree/main/packages/lint-functions#readme",
  "bugs": {
    "url": "https://github.com/amritk/mjst/issues"
  },
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsgo -p tsconfig.build.json && tsc-alias -p tsconfig.build.json -f",
    "types:check": "tsgo -p . --noEmit",
    "test": "NODE_ENV=production vitest run --root ../.. lint-functions"
  },
  "exports": {
    ".": {
      "development": "./src/index.ts",
      "default": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "dependencies": {
    "@amritk/lint-core": "workspace:*",
    "@amritk/runtime-validators": "workspace:*"
  }
}
