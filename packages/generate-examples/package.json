{
  "name": "@amritk/generate-examples",
  "version": "0.5.5",
  "description": "Generate fast-check arbitraries and example values from JSON Schemas.",
  "module": "./dist/index.js",
  "type": "module",
  "license": "MIT",
  "author": "amritk",
  "keywords": [
    "json-schema",
    "typescript",
    "fast-check",
    "property-testing",
    "test-data",
    "fixtures",
    "code-generation",
    "mjst"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/amritk/mjst.git",
    "directory": "packages/generate-examples"
  },
  "homepage": "https://github.com/amritk/mjst/tree/main/packages/generate-examples#readme",
  "bugs": {
    "url": "https://github.com/amritk/mjst/issues"
  },
  "files": [
    "dist",
    "AI.md"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsgo -p tsconfig.build.json && tsc-alias -p tsconfig.build.json -f && node ../../scripts/strip-comments.mjs",
    "types:check": "tsgo -p . --noEmit",
    "test": "NODE_ENV=production vitest run --root ../.. generate-examples"
  },
  "imports": {
    "#generators/*": "./src/generators/*.ts"
  },
  "exports": {
    ".": {
      "development": "./src/index.ts",
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "dependencies": {
    "json-schema-typed": "catalog:",
    "@amritk/helpers": "workspace:*",
    "@amritk/runtime-validators": "workspace:*"
  },
  "devDependencies": {
    "ajv": "^8.17.1"
  },
  "peerDependencies": {
    "fast-check": ">=3"
  },
  "peerDependenciesMeta": {
    "fast-check": {
      "optional": true
    }
  }
}
