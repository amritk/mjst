{
  "name": "@amritk/helpers",
  "version": "0.10.2",
  "description": "Shared utilities for the mjst code generation ecosystem.",
  "type": "module",
  "license": "MIT",
  "author": "amritk",
  "keywords": [
    "json-schema",
    "typescript",
    "mjst"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/amritk/mjst.git",
    "directory": "packages/helpers"
  },
  "homepage": "https://github.com/amritk/mjst/tree/main/packages/helpers#readme",
  "bugs": {
    "url": "https://github.com/amritk/mjst/issues"
  },
  "files": [
    "dist",
    "src/**/*.ts",
    "!src/**/*.test.ts"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsgo -p tsconfig.build.json && tsc-alias -p tsconfig.build.json -f",
    "types:check": "tsgo -p . --noEmit",
    "test": "NODE_ENV=production vitest run --root ../.. helpers"
  },
  "dependencies": {
    "json-schema-typed": "catalog:"
  },
  "exports": {
    "./package.json": "./package.json",
    "./*": {
      "development": "./src/*.ts",
      "import": "./dist/*.js",
      "types": "./dist/*.d.ts",
      "default": "./dist/*.js"
    }
  }
}
