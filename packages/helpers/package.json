{
  "name": "@amritk/helpers",
  "version": "0.6.2",
  "description": "Shared utilities for the mjst code generation ecosystem.",
  "type": "module",
  "license": "MIT",
  "author": "amritk",
  "keywords": [
    "json-schema",
    "typescript",
    "mjst"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/amritk/mjst.git",
    "directory": "packages/helpers"
  },
  "homepage": "https://github.com/amritk/mjst/tree/main/packages/helpers#readme",
  "bugs": {
    "url": "https://github.com/amritk/mjst/issues"
  },
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "bun run build:code && bun run build:types",
    "build:code": "bun build ./src/build-dynamic-ref-map.ts ./src/derive-root-type-name.ts ./src/extract-dynamic-anchor-defs.ts ./src/extract-refs.ts ./src/generate-index-barrel.ts ./src/generate-type-definition.ts ./src/has-ref.ts ./src/is-object.ts ./src/mjst-extension.ts ./src/parse-documentation.ts ./src/ref-to-filename.ts ./src/ref-to-name.ts ./src/resolve-dynamic-refs.ts ./src/resolve-ref.ts ./src/safe-accessor.ts ./src/schema-guards.ts ./src/upgrade-draft07-schema.ts ./src/validate-array.ts ./src/validate-record.ts ./src/walk-ref-graph.ts --outdir=dist --root=src --target=node",
    "build:types": "tsc -p ."
  },
  "dependencies": {
    "json-schema-typed": "catalog:"
  },
  "exports": {
    "./*": {
      "import": "./dist/*.js",
      "types": "./dist/*.d.ts",
      "default": "./dist/*.js"
    }
  }
}
