{
  "name": "@amritk/helpers",
  "version": "0.1.0",
  "description": "Shared utilities for the mjst code generation ecosystem.",
  "type": "module",
  "license": "MIT",
  "author": "amritk",
  "keywords": [
    "json-schema",
    "typescript",
    "mjst"
  ],
  "repository": {
