{
  "name": "@amritk/mjst",
  "version": "0.13.2",
  "description": "Generate TypeScript parsers and type definitions from JSON Schemas.",
  "type": "module",
  "license": "MIT",
  "author": "amritk",
  "keywords": [
    "json-schema",
    "typescript",
    "parser",
    "validator",
    "code-generation",
    "cli",
    "mjst"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/amritk/mjst.git",
    "directory": "packages/cli"
  },
  "homepage": "https://github.com/amritk/mjst/tree/main/packages/cli#readme",
  "bugs": {
    "url": "https://github.com/amritk/mjst/issues"
  },
  "bin": {
    "mjst": "./dist/cli.js"
  },
  "files": [
    "dist",
    "AI.md"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "dev": "bun run --conditions=development ./src/cli.ts",
    "start": "bun run ./src/cli.ts",
    "build": "tsgo -p tsconfig.build.json && tsc-alias -p tsconfig.build.json -f && node ../../scripts/strip-comments.mjs",
    "types:check": "tsgo -p . --noEmit",
    "test": "NODE_ENV=production vitest run --root ../.. cli",
    "generate-readme": "bun run ./scripts/generate-readme.ts"
  },
  "dependencies": {
    "@amritk/adapters": "workspace:*",
    "@amritk/api": "workspace:*",
    "@amritk/generate-examples": "workspace:*",
    "@amritk/generate-parsers": "workspace:*",
    "@amritk/generate-validators": "workspace:*",
    "@amritk/generate-markdown": "workspace:*",
    "@amritk/helpers": "workspace:*",
    "@amritk/lint": "workspace:*",
    "@amritk/resolve-refs": "workspace:*",
    "@amritk/yaml": "workspace:*",
    "fast-glob": "^3.3.2",
    "yargs": "^17.7.2"
  },
  "devDependencies": {
    "json-schema-typed": "catalog:",
    "@types/yargs": "^17.0.33"
  }
}
