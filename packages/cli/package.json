{
  "name": "@amritk/mjst",
  "version": "0.2.1",
  "description": "Generate TypeScript parsers and type definitions from JSON Schemas.",
  "type": "module",
  "license": "MIT",
  "author": "amritk",
  "keywords": [
    "json-schema",
    "typescript",
    "parser",
    "validator",
    "code-generation",
    "cli",
    "mjst"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/amritk/mjst.git",
    "directory": "packages/cli"
  },
  "homepage": "https://github.com/amritk/mjst/tree/main/packages/cli#readme",
  "bugs": {
    "url": "https://github.com/amritk/mjst/issues"
  },
  "bin": {
    "mjst": "./dist/cli.js"
  },
  "files": [
    "dist",
    "src"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "dev": "bun run --filter='@amritk/generate-parsers' build:runtime-helpers && bun run --conditions=development ./src/cli.ts",
    "start": "bun run --filter='@amritk/generate-parsers' build:runtime-helpers && bun run ./src/cli.ts",
    "build": "bun run build:code && bun run build:types",
    "build:code": "bun build ./src/cli.ts --outdir=dist --target=node",
    "build:types": "tsc -p .",
    "generate-readme": "bun run ./scripts/generate-readme.ts"
  },
  "dependencies": {
    "@amritk/generate-parsers": "workspace:*",
    "@amritk/generate-markdown": "workspace:*",
    "@amritk/helpers": "workspace:*"
  },
  "devDependencies": {
    "json-schema-typed": "catalog:"
  }
}
