{
  "name": "@amritk/mjst",
  "version": "0.1.0",
  "description": "Generate TypeScript parsers and type definitions from JSON Schemas.",
  "type": "module",
  "license": "MIT",
  "author": "amritk",
  "keywords": [
    "json-schema",
    "typescript",
    "parser",
    "validator",
    "code-generation",
    "cli",
    "mjst"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/amritk/mjst.git",
    "directory": "packages/cli"
  },
  "homepage": "https://github.com/amritk/mjst/tree/main/packages/cli#readme",
  "bugs": {
    "url": "https://github.com/amritk/mjst/issues"
  },
  "bin": {
    "mjst": "./dist/cli.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "dev": "tsx ./src/cli.ts",
    "start": "node ./dist/cli.js",
    "build": "tsup",
    "typecheck": "tsc -p .",
    "generate-readme": "tsx ./scripts/generate-readme.ts"
  },
  "dependencies": {
    "@amritk/generate-parsers": "workspace:*",
    "@amritk/helpers": "workspace:*",
    "typescript": "^5"
  },
  "devDependencies": {
    "@amritk/generate-markdown": "workspace:*",
    "json-schema-typed": "^8.0.1"
  }
}
