{
  "name": "mjst-cli",
  "version": "0.1.0",
  "description": "[pre-alpha] Generate TypeScript parsers and type definitions from JSON Schemas.",
  "module": "cli.ts",
  "type": "module",
  "bin": {
    "mjst": "./src/cli.ts"
  },
  "scripts": {
    "dev": "bun run --conditions=development ./src/cli.ts",
    "start": "bun run ./src/cli.ts",
    "generate-readme": "bun run ./src/cli.ts --markdown"
  },
  "dependencies": {
    "generate-parsers": "workspace:*",
    "generate-markdown": "workspace:*"
  },
  "devDependencies": {
    "json-schema-typed": "catalog:"
  }
}
