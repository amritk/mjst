{
  "name": "@amritk/generate-validators",
  "version": "0.7.0",
  "description": "Generate TypeScript validation functions from JSON Schemas.",
  "module": "./dist/index.js",
  "type": "module",
  "license": "MIT",
  "author": "amritk",
  "keywords": [
    "json-schema",
    "typescript",
    "validator",
    "validation",
    "code-generation",
    "mjst"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/amritk/mjst.git",
    "directory": "packages/generate-validators"
  },
  "homepage": "https://github.com/amritk/mjst/tree/main/packages/generate-validators#readme",
  "bugs": {
    "url": "https://github.com/amritk/mjst/issues"
  },
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsgo -p tsconfig.build.json && tsc-alias -p tsconfig.build.json -f",
    "types:check": "tsgo -p . --noEmit",
    "test": "NODE_ENV=production vitest run --root ../.. generate-validators",
    "bench": "bun run ./bench/run.ts"
  },
  "imports": {
    "#generators/*": "./src/generators/*.ts"
  },
  "exports": {
    ".": {
      "development": "./src/index.ts",
      "default": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "dependencies": {
    "json-schema-typed": "catalog:",
    "@amritk/helpers": "workspace:*"
  },
  "devDependencies": {
    "@scalar/openapi-parser": "^0.26.1",
    "@sinclair/typebox": "^0.34.49",
    "ajv": "^8.17.1",
    "ajv-formats": "^3.0.1",
    "zod": "^4.4.3"
  }
}
