{
  "name": "@amritk/generate-validators",
  "version": "0.1.0",
  "description": "Generate TypeScript validation functions from JSON Schemas.",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "license": "MIT",
  "author": "amritk",
  "keywords": [
    "json-schema",
    "typescript",
    "validator",
    "validation",
    "code-generation",
    "mjst"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/amritk/mjst.git",
    "directory": "packages/generate-validators"
  },
  "homepage": "https://github.com/amritk/mjst/tree/main/packages/generate-validators#readme",
  "bugs": {
    "url": "https://github.com/amritk/mjst/issues"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc -p ."
  },
  "imports": {
    "#generators/*": "./src/generators/*.ts"
  },
  "exports": {
    ".": {
      "development": "./src/index.ts",
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "dependencies": {
    "json-schema-typed": "^8.0.1",
    "@amritk/helpers": "workspace:*"
  },
  "devDependencies": {
    "@scalar/openapi-parser": "^0.26.1"
  }
}
