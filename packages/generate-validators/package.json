{
  "name": "@amritk/generate-validators",
  "version": "0.4.0",
  "description": "Generate TypeScript validation functions from JSON Schemas.",
  "module": "./dist/index.js",
  "type": "module",
  "license": "MIT",
  "author": "amritk",
  "keywords": [
    "json-schema",
    "typescript",
    "validator",
    "validation",
    "code-generation",
    "mjst"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/amritk/mjst.git",
    "directory": "packages/generate-validators"
  },
  "homepage": "https://github.com/amritk/mjst/tree/main/packages/generate-validators#readme",
  "bugs": {
    "url": "https://github.com/amritk/mjst/issues"
  },
  "files": [
    "dist",
    "src"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "bun run build:code && bun run build:types",
    "build:code": "bun build ./src/index.ts --outdir=dist --target=node",
    "build:types": "tsc -p ."
  },
  "imports": {
    "#generators/*": "./src/generators/*.ts"
  },
  "exports": {
    ".": {
      "bun": "./src/index.ts",
      "default": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "dependencies": {
    "json-schema-typed": "catalog:",
    "@amritk/helpers": "workspace:*"
  },
  "devDependencies": {
    "@scalar/openapi-parser": "^0.26.1"
  }
}
