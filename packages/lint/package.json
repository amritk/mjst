{
  "name": "@amritk/lint",
  "version": "0.2.0",
  "description": "A fast, format-agnostic JSON/YAML style-guide linter with JSON Schema and custom rules.",
  "module": "./dist/index.js",
  "type": "module",
  "license": "MIT",
  "author": "amritk",
  "keywords": [
    "lint",
    "linter",
    "json",
    "yaml",
    "json-schema",
    "style-guide",
    "ruleset",
    "typescript",
    "mjst"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/amritk/mjst.git",
    "directory": "packages/lint"
  },
  "homepage": "https://github.com/amritk/mjst/tree/main/packages/lint#readme",
  "bugs": {
    "url": "https://github.com/amritk/mjst/issues"
  },
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsgo -p tsconfig.build.json && tsc-alias -p tsconfig.build.json -f && node scripts/copy-schema-json.mjs",
    "types:check": "tsgo -p . --noEmit",
    "test": "NODE_ENV=production vitest run --root ../.. packages/lint/",
    "prebench": "bun run --filter='@amritk/runtime-validators' --filter='@amritk/yaml' --filter='@amritk/resolve-refs' build",
    "bench": "bun run ./bench/run.ts"
  },
  "exports": {
    "./package.json": "./package.json",
    ".": {
      "development": "./src/index.ts",
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./rules/openapi": {
      "development": "./src/rules/openapi/index.ts",
      "types": "./dist/rules/openapi/index.d.ts",
      "default": "./dist/rules/openapi/index.js"
    }
  },
  "dependencies": {
    "@amritk/runtime-validators": "workspace:*",
    "@amritk/yaml": "workspace:*",
    "jsonc-parser": "^3.3.1"
  },
  "devDependencies": {
    "@amritk/resolve-refs": "workspace:*",
    "@stoplight/spectral-core": "^1.23.1",
    "@stoplight/spectral-parsers": "^1.0.5",
    "@stoplight/spectral-rulesets": "^1.22.6"
  }
}
