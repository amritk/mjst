{
  "name": "@amritk/generate-parsers",
  "version": "0.1.0",
  "description": "Generate TypeScript parsers and type definitions from JSON Schemas.",
  "module": "./dist/index.js",
  "type": "module",
  "license": "MIT",
  "author": "amritk",
  "keywords": [
    "json-schema",
    "openapi",
    "asyncapi",
    "typescript",
    "parser",
    "code-generation",
    "mjst"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/amritk/mjst.git",
    "directory": "packages/generate-parsers"
  },
  "homepage": "https://github.com/amritk/mjst/tree/main/packages/generate-parsers#readme",
  "bugs": {
    "url": "https://github.com/amritk/mjst/issues"
  },
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "bun run build:code && bun run build:types",
    "build:code": "bun build ./src/index.ts --outdir=dist",
    "build:types": "tsc -p ."
  },
  "imports": {
    "#generators/*": "./src/generators/*.ts",
    "#helpers/*": "./src/helpers/*.ts",
    "#types/*": "./src/types/*.ts",
    "#templates/*": "./src/templates/*.ts"
  },
  "exports": {
    ".": {
      "bun": "./src/index.ts",
      "default": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "dependencies": {
    "@scalar/typebox": "^0.1.3",
    "json-schema-typed": "catalog:",
    "@amritk/helpers": "workspace:*"
  }
}
