{
  "name": "generate-parsers",
  "version": "0.1.0",
  "description": "Generate TypeScript parsers and type definitions from JSON Schemas.",
  "module": "./dist/index.js",
  "type": "module",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "bun run build:code && bun run build:types",
    "build:code": "bun build ./src/index.ts --outdir=dist",
    "build:types": "tsc -p ."
  },
  "imports": {
    "#generators/*": "./src/generators/*.ts",
    "#helpers/*": "./src/helpers/*.ts",
    "#type-guards/*": "./src/type-guards/*.ts",
    "#types/*": "./src/types/*.ts",
    "#validators/*": "./src/validators/*.ts",
    "#templates/*": "./src/templates/*.ts"
  },
  "exports": {
    ".": {
      "bun": "./src/index.ts",
      "default": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "dependencies": {
    "@scalar/openapi-parser": "^0.25.8",
    "@scalar/typebox": "^0.1.3",
    "json-schema-typed": "catalog:",
    "mjst-helpers": "workspace:*",
    "vitest": "^4.1.2"
  }
}
