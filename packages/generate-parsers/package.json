{
  "name": "@amritk/generate-parsers",
  "version": "0.1.0",
  "description": "Generate TypeScript parsers and type definitions from JSON Schemas.",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "license": "MIT",
  "author": "amritk",
  "keywords": [
    "json-schema",
    "typescript",
    "parser",
    "code-generation",
    "mjst"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/amritk/mjst.git",
    "directory": "packages/generate-parsers"
  },
  "homepage": "https://github.com/amritk/mjst/tree/main/packages/generate-parsers#readme",
  "bugs": {
    "url": "https://github.com/amritk/mjst/issues"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc -p .",
    "generate-readme": "tsx ./scripts/generate-readme.ts"
  },
  "imports": {
    "#generators/*": "./src/generators/*.ts",
    "#helpers/*": "./src/helpers/*.ts",
    "#types/*": "./src/types/*.ts"
  },
  "exports": {
    ".": {
      "development": "./src/index.ts",
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "dependencies": {
    "json-schema-typed": "^8.0.1",
    "@amritk/helpers": "workspace:*"
  },
  "devDependencies": {
    "@amritk/generate-markdown": "workspace:*"
  }
}
