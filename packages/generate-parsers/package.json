{
  "name": "@amritk/generate-parsers",
  "version": "0.16.0",
  "description": "Generate TypeScript parsers and type definitions from JSON Schemas.",
  "module": "./dist/index.js",
  "type": "module",
  "license": "MIT",
  "author": "amritk",
  "keywords": [
    "json-schema",
    "typescript",
    "parser",
    "code-generation",
    "mjst"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/amritk/mjst.git",
    "directory": "packages/generate-parsers"
  },
  "homepage": "https://github.com/amritk/mjst/tree/main/packages/generate-parsers#readme",
  "bugs": {
    "url": "https://github.com/amritk/mjst/issues"
  },
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsgo -p tsconfig.build.json && tsc-alias -p tsconfig.build.json -f",
    "types:check": "tsgo -p . --noEmit",
    "test": "NODE_ENV=production vitest run --root ../.. generate-parsers",
    "generate-readme": "bun run ./scripts/generate-readme.ts",
    "bench": "bun --conditions development ./bench/run.ts"
  },
  "imports": {
    "#generators/*": "./src/generators/*.ts",
    "#helpers/*": "./src/helpers/*.ts",
    "#types/*": "./src/types/*.ts"
  },
  "exports": {
    ".": {
      "development": "./src/index.ts",
      "default": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "dependencies": {
    "json-schema-typed": "catalog:",
    "@amritk/helpers": "workspace:*",
    "@amritk/generate-markdown": "workspace:*"
  },
  "devDependencies": {
    "@sinclair/typebox": "^0.34.49",
    "ajv": "^8.17.1",
    "zod": "^4.4.3"
  }
}
