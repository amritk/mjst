{
  "name": "@amritk/lint-parsers",
  "version": "0.0.0",
  "description": "YAML/JSON parsing with exact source positions for the lint engine.",
  "module": "./dist/index.js",
  "type": "module",
  "license": "MIT",
  "author": "amritk",
  "keywords": [
    "yaml",
    "json",
    "parser",
    "source-map",
    "lint",
    "linter",
    "typescript",
    "mjst"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/amritk/mjst.git",
    "directory": "packages/lint-parsers"
  },
  "homepage": "https://github.com/amritk/mjst/tree/main/packages/lint-parsers#readme",
  "bugs": {
    "url": "https://github.com/amritk/mjst/issues"
  },
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsgo -p tsconfig.build.json && tsc-alias -p tsconfig.build.json -f",
    "types:check": "tsgo -p . --noEmit",
    "test": "NODE_ENV=production vitest run --root ../.. lint-parsers"
  },
  "exports": {
    ".": {
      "development": "./src/index.ts",
      "default": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "dependencies": {
    "@amritk/yaml": "workspace:*",
    "jsonc-parser": "^3.3.1"
  }
}
