{
  "name": "@amritk/yaml",
  "version": "0.3.4",
  "description": "A fast, featherweight, zero-dependency YAML parser for OpenAPI tooling — with exact source positions (line:column) on every node.",
  "module": "./dist/index.js",
  "type": "module",
  "license": "MIT",
  "author": "amritk",
  "keywords": [
    "yaml",
    "parser",
    "yaml-parser",
    "source-map",
    "diagnostics",
    "lint",
    "openapi",
    "typescript",
    "fast",
    "mjst"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/amritk/mjst.git",
    "directory": "packages/yaml"
  },
  "homepage": "https://github.com/amritk/mjst/tree/main/packages/yaml#readme",
  "bugs": {
    "url": "https://github.com/amritk/mjst/issues"
  },
  "files": [
    "dist",
    "AI.md"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsgo -p tsconfig.build.json && tsc-alias -p tsconfig.build.json -f && node ../../scripts/strip-comments.mjs",
    "types:check": "tsgo -p . --noEmit",
    "test": "NODE_ENV=production vitest run --root ../.. yaml",
    "bench": "bun run ./bench/run.ts"
  },
  "exports": {
    ".": {
      "development": "./src/index.ts",
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "devDependencies": {
    "js-yaml": "^4.1.0",
    "yaml": "^2.6.0"
  }
}
