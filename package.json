{
  "name": "mjst",
  "private": true,
  "workspaces": [
    "packages/*"
  ],
  "catalog": {
    "json-schema-typed": "^8.0.1"
  },
  "type": "module",
  "keywords": [
    "json",
    "validation",
    "parsing",
    "parser",
    "schema",
    "typescript",
    "validator"
  ],
  "author": "amritk",
  "license": "MIT",
  "scripts": {
    "bench": "bun test --bench",
    "generate:fixtures:2.0": "bun run ./packages/cli/src/cli.ts --schema fixtures/2.0-2017-08-27.json --docs fixtures/2.0.md --outDir fixtures/generate-parsers/2.0",
    "generate:fixtures:3.0.4": "bun run ./packages/cli/src/cli.ts --schema fixtures/3.0.4-2024-10-18.json --docs fixtures/3.0.4.md --outDir fixtures/generate-parsers/3.0.4",
    "generate:fixtures:3.1.2": "bun run ./packages/cli/src/cli.ts --schema fixtures/3.1.2-2025-09-15.json --docs fixtures/3.1.2.md --outDir fixtures/generate-parsers/3.1.2",
    "generate:fixtures:3.2.0": "bun run ./packages/cli/src/cli.ts --schema fixtures/3.2.0-2025-11-23.json --docs fixtures/3.2.0.md --outDir fixtures/generate-parsers/3.2.0",
    "generate:fixtures:async:3.1.0": "bun run ./packages/cli/src/cli.ts --schema fixtures/asyncapi-3.1.0.json --docs fixtures/asyncapi-3.1.0.md --outDir fixtures/generate-parsers/asyncapi/3.1.0 --build",
    "generate:fixtures:2.0:types": "bun run ./packages/cli/src/cli.ts --schema fixtures/2.0-2017-08-27.json --docs fixtures/2.0.md --outDir fixtures/generate-parsers/2.0 --types-only --build",
    "generate:fixtures:3.0.4:types": "bun run ./packages/cli/src/cli.ts --schema fixtures/3.0.4-2024-10-18.json --docs fixtures/3.0.4.md --outDir fixtures/generate-parsers/3.0.4 --types-only --build",
    "generate:fixtures:3.1.2:types": "bun run ./packages/cli/src/cli.ts --schema fixtures/3.1.2-2025-09-15.json --docs fixtures/3.1.2.md --outDir fixtures/generate-parsers/3.1.2 --types-only --build",
    "generate:fixtures:3.2.0:types": "bun run ./packages/cli/src/cli.ts --schema fixtures/3.2.0-2025-11-23.json --docs fixtures/3.2.0.md --outDir fixtures/generate-parsers/3.2.0 --types-only --build",
    "generate:fixtures:async:3.1.0:types": "bun run ./packages/cli/src/cli.ts --schema fixtures/asyncapi-3.1.0.json --docs fixtures/asyncapi-3.1.0.md --outDir fixtures/generate-parsers/asyncapi/3.1.0 --types-only --build",
    "generate:all": "bun run generate:fixtures:2.0 && bun run generate:fixtures:3.0.4 && bun run generate:fixtures:3.1.2 && bun run generate:fixtures:3.2.0",
    "generate:all:types": "bun run generate:fixtures:2.0:types && bun run generate:fixtures:3.0.4:types && bun run generate:fixtures:3.1.2:types && bun run generate:fixtures:3.2.0:types && bun run generate:fixtures:async:3.1.0:types",
    "check": "bun run biome check .",
    "format": "bun run biome format --write .",
    "test": "bun test"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.4",
    "@changesets/cli": "^2.30.0",
    "@types/bun": "latest",
    "tinybench": "^6.0.0"
  },
  "peerDependencies": {
    "typescript": "^5"
  },
  "dependencies": {
    "@scalar/typebox": "^0.1.3",
    "@scalar/validation": "^0.1.0",
    "@scalar/workspace-store": "^0.41.2"
  }
}
