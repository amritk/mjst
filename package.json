{
  "name": "mjst",
  "private": true,
  "workspaces": [
    "packages/*"
  ],
  "catalog": {
    "json-schema-typed": "^8.0.1"
  },
  "type": "module",
  "keywords": [
    "json",
    "validation",
    "parsing",
    "parser",
    "schema",
    "typescript",
    "validator"
  ],
  "author": "amritk",
  "license": "MIT",
  "scripts": {
    "bench": "bun test --bench",
