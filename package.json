{
  "name": "mjst",
  "private": true,
  "workspaces": [
    "packages/*"
  ],
  "catalog": {
    "json-schema-typed": "^8.0.1"
  },
  "type": "module",
  "keywords": [
    "json",
    "validation",
    "parsing",
    "parser",
    "schema",
    "typescript",
    "validator"
  ],
  "author": "amritk",
  "license": "MIT",
  "scripts": {
    "generate-readmes": "(cd packages/cli && bun run generate-readme) && (cd packages/generate-parsers && bun run generate-readme)",
    "build": "bun run --workspaces build",
    "dev": "bun --conditions development packages/cli/src/cli.ts",
    "types:check": "bun run --workspaces types:check",
    "lint:check": "bun run check",
    "check": "biome check .",
    "format": "biome check --write --formatter-enabled=true --linter-enabled=false .",
    "lint": "biome lint .",
    "test": "bun run --workspaces test",
    "test:seq": "bun run --workspaces --sequential test",
    "release:version": "changeset version && bun install --no-frozen-lockfile",
    "release:publish": "bun run scripts/resolve-workspace-protocol.ts && changeset publish"
  },
  "devDependencies": {
    "@amritk/helpers": "workspace:*",
    "@biomejs/biome": "2.4.4",
    "@changesets/cli": "^2.30.0",
    "@sinclair/typebox": "^0.34.49",
    "@types/node": "^25.9.1",
    "@typescript/native-preview": "^7.0.0-dev.20260524.1",
    "@valibot/to-json-schema": "^1.7.0",
    "effect": "^3.21.2",
    "ts-go": "^1.0.4",
    "tsc-alias": "^1.8.17",
    "typescript": "^5",
    "valibot": "^1.4.0",
    "vitest": "^4.1.5",
    "zod": "^4.4.3"
  }
}
