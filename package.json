{
  "name": "mjst",
  "private": true,
  "workspaces": [
    "packages/*"
  ],
  "catalog": {
    "json-schema-typed": "^8.0.1"
  },
  "type": "module",
  "keywords": [
    "json",
    "validation",
    "parsing",
    "parser",
    "schema",
    "typescript",
    "validator"
  ],
  "author": "amritk",
  "license": "MIT",
  "scripts": {
    "generate-readmes": "(cd packages/cli && bun run generate-readme) && (cd packages/generate-parsers && bun run generate-readme)",
    "check": "bun run biome check .",
    "format": "bun run biome format --write .",
    "test": "vitest run",
    "build": "bun run --filter='./packages/*' build",
    "release:version": "changeset version && bun install --no-frozen-lockfile",
    "release:publish": "bun run scripts/resolve-workspace-protocol.ts && changeset publish"
  },
  "devDependencies": {
    "@amritk/helpers": "workspace:*",
    "@biomejs/biome": "2.4.4",
    "@changesets/cli": "^2.30.0",
    "@sinclair/typebox": "^0.34.49",
    "@types/bun": "latest",
    "@valibot/to-json-schema": "^1.7.0",
    "effect": "^3.21.2",
    "typescript": "^5",
    "valibot": "^1.4.0",
    "vitest": "^4.1.5",
    "zod": "^4.4.3"
  }
}
