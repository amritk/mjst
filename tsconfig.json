{
  "compilerOptions": {
    // Environment setup & latest features
    "lib": ["ESNext"],
    "target": "ESNext",
    "module": "Preserve",
    "moduleDetection": "force",

    // Bundler mode
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "verbatimModuleSyntax": true,
    "noEmit": true,

    // Best practices
    "strict": true,
    "skipLibCheck": true,
    "noFallthroughCasesInSwitch": true,
    "noUncheckedIndexedAccess": true,
    "noImplicitOverride": true,
    "allowUnusedLabels": false,
    "allowUnreachableCode": false,
    "exactOptionalPropertyTypes": true,

    // Some stricter flags (disabled by default)
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noPropertyAccessFromIndexSignature": true,

    // Workspace package resolution (Bun doesn't symlink workspace packages)
    "paths": {
      "mjst-helpers/*": ["./packages/helpers/src/*"],
      "generate-parsers/generators/*": ["./packages/generate-parsers/src/generators/*"],
      "generate-parsers/helpers/*": ["./packages/generate-parsers/src/helpers/*"],
      "generate-parsers/type-guards/*": ["./packages/generate-parsers/src/type-guards/*"]
    }
  }
}
